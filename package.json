{
  "name": "munchkins",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "munchkins": "MUNCHKINS_CHANGELOG_PATH=docs/pages/changelog.md bun run packages/munchkins/src/index.ts",
    "release": "bun run scripts/release.ts",
    "scenario": "bun run scenarios/index.ts && bun run scenarios/composition.ts && bun run scenarios/resume-after-claude-exit-e2e.ts && bun run scenarios/director-multi-dispatch-e2e.ts && bun run scenarios/agent-uncommitted-smoke-e2e.ts",
    "docs:dev": "turbo run dev --filter=docs",
    "docs:build": "turbo run build --filter=docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@serranolabs.io/munchkins": "workspace:*",
    "@serranolabs.io/munchkins-core": "workspace:*",
    "@types/bun": "^1.3.0",
    "turbo": "^2.5.2",
    "typescript": "^5.4.0"
  }
}
